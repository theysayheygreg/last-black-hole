{
  "name": "last-black-hole",
  "version": "0.2.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node scripts/stack.js start --mode=local-host",
    "stop": "node scripts/stack.js stop",
    "dev": "node scripts/dev-server.js start",
    "dev:stop": "node scripts/dev-server.js stop",
    "dev:status": "node scripts/dev-server.js status",
    "dev:restart": "node scripts/dev-server.js restart",
    "stack": "node scripts/stack.js start --mode=local-host",
    "stack:browser": "node scripts/stack.js start --mode=local-browser",
    "stack:remote": "node scripts/stack.js start --mode=remote-client",
    "stack:stop": "node scripts/stack.js stop",
    "stack:status": "node scripts/stack.js status",
    "stack:restart": "node scripts/stack.js restart --mode=local-host",
    "sim": "node scripts/sim-server.js start",
    "sim:stop": "node scripts/sim-server.js stop",
    "sim:status": "node scripts/sim-server.js status",
    "sim:restart": "node scripts/sim-server.js restart",
    "control": "node scripts/control-plane-server.js start",
    "control:stop": "node scripts/control-plane-server.js stop",
    "control:status": "node scripts/control-plane-server.js status",
    "control:restart": "node scripts/control-plane-server.js restart",
    "test": "node tests/run-all.js",
    "test:renderer": "node tests/renderer.js",
    "test:audio": "node tests/audio-toolkit.js",
    "audio:analyze": "sh -c 'PY=.venv/bin/python; [ -x \"$PY\" ] || PY=python3; exec \"$PY\" tools/audio_workbench.py \"$@\"' --",
    "build": "node scripts/build.js",
    "build:release": "node scripts/build.js --mode=release",
    "build:test": "node scripts/build.js --mode=test",
    "build:dev": "node scripts/build.js --mode=dev",
    "build:web": "node scripts/build.js --targets=web",
    "build:desktop": "node scripts/build.js --targets=web,mac,win,linux,ipad"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "puppeteer": "^24.39.1"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^41.0.2"
  }
}
